services:
  metakavita:
    image: ghcr.io/raukorim-bot/metakavita:latest
    container_name: metakavita
    restart: unless-stopped
    ports:
      - "5010:5010"
    extra_hosts:
      - "host.docker.internal:host-gateway"
    environment:
      # --- Variables Optionnelles / Optional Variables ---
      # Toutes ces valeurs peuvent être configurées plus tard, directement depuis l'interface Web.
      # All these values can be configured later directly from the Web UI.
      
      # - KAVITA_URL=http://ton-kavita:5001
      # - KAVITA_API_KEY=ta_cle_api_kavita
      # - DEEPL_API_KEY=ta_cle_api_deepl
      # - TARGET_LANG=FR
      # - UI_LANG=fr
      # - PROVIDER_1=MANGABAKA
      # - PROVIDER_2=NAUTILJON
      # - PROVIDER_3=ANILIST
      # - SMART_COMPLETION=false
      # - AUTO_SYNC_INTERVAL=0
      # - AUTO_COVER=false
      
    volumes:
      # Le dossier 'data' contiendra le config.json, la base de données cache.db et les logs.
      - ./data:/app/data